        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "points",
            "fillOpacity": 100,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 10,
            "showPoints": "always",
            "spanNulls": false
